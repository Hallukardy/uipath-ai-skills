<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010" x:Class="Lint018Good"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sd="clr-namespace:System.Drawing;assembly=System.Drawing.Common"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- GOOD: sd is bound to System.Drawing.Common (correct assembly for sd:Image) -->
  <Sequence DisplayName="Main" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <ui:OCREngine DisplayName="Tesseract OCR"
      sap2010:WorkflowViewState.IdRef="OCREngine_1">
      <ActivityAction x:TypeArguments="sd:Image">
        <ActivityAction.Argument>
          <DelegateInArgument x:TypeArguments="sd:Image" Name="img" />
        </ActivityAction.Argument>
        <Sequence DisplayName="Body" sap2010:WorkflowViewState.IdRef="Sequence_2" />
      </ActivityAction>
    </ui:OCREngine>
  </Sequence>
</Activity>
