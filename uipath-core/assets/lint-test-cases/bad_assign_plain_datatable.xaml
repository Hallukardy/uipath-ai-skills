<Activity mc:Ignorable="sap sap2010" x:Class="TestBadPlainAssignDataTable" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation" xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation" xmlns:sd="clr-namespace:System.Data;assembly=System.Data.Common" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Sequence DisplayName="Test" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <Sequence.Variables>
      <Variable x:TypeArguments="sd:DataTable" Name="dt_Transactions" />
    </Sequence.Variables>
    <!-- Plain Assign with x:String TypeArguments but the variable is DataTable.
         Studio rejects with BC30311. Rule 113 should flag it. -->
    <Assign DisplayName="Assign - dt_Transactions" sap:VirtualizedContainerService.HintSize="600,175" sap2010:WorkflowViewState.IdRef="Assign_1">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[dt_Transactions]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[dt_Transactions.Select(&quot;Type = 'WI5'&quot;).CopyToDataTable()]</InArgument>
      </Assign.Value>
    </Assign>
  </Sequence>
</Activity>
